---
import { Icon } from "astro-icon/components";

import ItemExperience from "./common/ItemExperience.astro";
import cidenet from "../assets/images/cidenet.webp";
import grupo_jpc from "../assets/images/grupo_jpc.webp";
import fga from "../assets/images/fga.webp";
import gbi_mark from "../assets/images/gbi_mark.webp";
import lebon from "../assets/images/lebon.webp";
import software_estrategico from "../assets/images/software_estrategico.webp";
---

<section id="experience" class="bg-slate-50/60 py-16 md:py-20 dark:bg-slate-900/60">
  <div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-center gap-2 text-center">
      <Icon name="proicons:layers" class="h-8 w-8 text-slate-700 sm:h-10 sm:w-10 dark:text-slate-300" />
      <h1 class="py-2 text-3xl font-bold text-slate-900 sm:text-4xl md:text-5xl dark:text-slate-100">
        Experiencia
      </h1>
    </div>
    <div class="mt-8 grid grid-cols-1 gap-x-8 gap-y-6 xl:grid-cols-2">
      <ItemExperience
        image={cidenet}
        title="Cidenet"
        position="Desarrollador Frontend"
        dateIn="2022"
        dateOut="Actual"
        description="Como Analista de Tecnología en Cidenet, me especialicé en el desarrollo de software utilizando <strong>PHP, JavaScript, JQuery, AJAX, CSS y HTML</strong>. Entre mis principales responsabilidades se destacó la implementación de mejoras en un software para la atención de pacientes en una clínica, optimizando su funcionalidad y eficiencia. Mi rol implicó colaboración con el equipo de desarrollo, para garantizar la calidad del producto y asegurar que las soluciones estuvieran alineadas con los requerimientos del cliente."
        url="https://cidenet.com.co/"
      />
      <ItemExperience
        image={grupo_jpc}
        title="Grupo JPC"
        position="Desarrollador TI"
        dateIn="2019"
        dateOut="2022"
        description="Como Desarrollador TI en Grupo JPC, me encargué de personalizar el CRM Vtiger <strong>(PHP)</strong> para adaptarlo a las necesidades específicas de la empresa. Desarrollé un sistema para el pago de facturas utilizando <strong>Angular</strong> y <strong>Node.JS</strong>, el cual se integraba con el CRM para mantener actualizada la información de facturación. Además, implementé un sistema para el seguimiento de pedidos, lo que permitió a la empresa mejorar la gestión y trazabilidad de las solicitudes realizadas por los clientes."
        url="https://www.megatoner.co/"
      />

      <ItemExperience
        image={fga}
        title="FGA Fondo de garantías"
        position="Analista de Tecnología"
        dateIn="2016"
        dateOut="2019"
        description="Como Analista de Tecnología, fui responsable de migrar de SugarCRM a SUITECRM, lo cual me permitió optimizar el sistema de gestión de clientes y la administración de PQRS. Participé activamente en el desarrollo de gestión de procesos a través  de la implementación de nuevos módulos en el CRM, donde utilicé <strong>PHP</strong> como lenguaje de programación principal, junto con <strong>HTML, CSS y JavaScript</strong> para adaptar el sistema a las necesidades de la empresa."
        url="https://fga.com.co/"
      />

      <ItemExperience
        image={gbi_mark}
        title="GBI-Mark"
        position="Desarrollador TI"
        dateIn="2015"
        dateOut="2016"
        description="En mi rol como Desarrollador TI, me encargué de diseñar y desarrollar interfaces de usuario intuitivas utilizando <strong>PHP, HTML y CSS,</strong> para mejorar la experiencia del usuario en los CRM SugarCRM y SuiteCRM. Fui parte del equipo que implementó la plataforma para cada uno de los clientes, lo que resultó en un aumento de eficiencia y productividad en los procesos de cada uno. Además, realicé integraciones con otros sistemas y optimicé el rendimiento de los módulos del CRM, reduciendo los tiempos de carga."
        url="https://gbi-mark.com/"
      />

      <ItemExperience
        image={lebon}
        title="LeBon"
        position="Analista Desarrollador"
        dateIn="2014"
        dateOut="2015"
        description="Como Analista Desarrollador, implementé nuevos módulos personalizados para el ERP LeBon. Utilice <strong>PHP</strong> con base de datos <strong>MySQL</strong>. Realicé la integración de módulos externos y optimicé el rendimiento del sistema. Mis desarrollos contribuyeron a mejorar los procesos de la empresa, aumentando la eficiencia y productividad."
        url="https://www.facebook.com/LebonTiendaOnline/"
      />

      <ItemExperience
        image={software_estrategico}
        title="Software Estratégico"
        position="Analista Desarrollador"
        dateIn="2013"
        dateOut="2014"
        description="Como Analista Desarrollador, me encargué de diseñar y personalizar los módulos del ERP, utilizando <strong>PHP</strong> con base de datos <strong>MySQL y CSS,</strong> para mejorar la experiencia en el sistema en una empresa que prestaba el servicio de dispensación de medicamentos a las diferentes EPS de Colombia. Realicé la integración de módulos externos y optimicé el rendimiento del sistema. Mis desarrollos contribuyeron a mejorar los procesos de la empresa, aumentando la eficiencia y productividad."
        url="https://softgic.co/es/"
      />
    </div>
  </div>
</section>
