---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import profile from "../assets/perfil.webp";
import curriculum from "../assets/docs/HOJA_DE_VIDA_ANDRES_FELIPE_MEJIA_RESTREPO.pdf";
---

<section
  id="profile"
  class="mx-auto grid w-full max-w-6xl items-center gap-10 px-4 pb-16 pt-10 sm:px-6 md:pb-20 md:pt-16 lg:grid-cols-[auto,1fr] lg:gap-14 lg:px-8"
>
  <div class="mx-auto">
    <Image
      src={profile}
      alt="Andrés Felipe Mejía Restrepo"
      class="h-56 w-56 rounded-full object-cover ring-4 ring-slate-200 shadow-xl shadow-slate-900/10 sm:h-72 sm:w-72 lg:h-80 lg:w-80 dark:ring-slate-700"
    />
  </div>
  <div class="text-center lg:text-left">
    <p class="text-base font-semibold text-slate-500 sm:text-lg dark:text-slate-400">Hola, soy</p>
    <h1
      class="mt-2 text-balance py-2 text-4xl font-bold leading-tight text-slate-900 sm:text-5xl lg:text-6xl dark:text-slate-100"
    >
      Andrés Felipe Mejía
    </h1>
    <p class="mt-3 text-lg font-semibold text-slate-600 sm:text-2xl dark:text-slate-300">
      Desarrollador FullStack.
    </p>
    <div
      class="mt-4 inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-600 shadow-sm sm:text-base dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300"
    >
      <Icon name="hugeicons:location-01" class="h-5 w-5" />
      <span>Manizales, Colombia</span>
    </div>
    <div class="mt-8 flex flex-wrap justify-center gap-3 lg:justify-start">
      <a
        href={curriculum}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-full border border-slate-800 px-5 py-2.5 text-sm font-medium text-slate-900 transition hover:-translate-y-0.5 hover:bg-slate-900 hover:text-white dark:border-slate-300 dark:text-slate-100 dark:hover:bg-slate-200 dark:hover:text-slate-950"
      >
        Descargar CV
      </a>
      <a
        href="#contact"
        class="inline-flex items-center justify-center rounded-full border border-slate-900 bg-slate-900 px-5 py-2.5 text-sm font-medium text-white transition hover:-translate-y-0.5 hover:bg-slate-700 dark:border-slate-200 dark:bg-slate-100 dark:text-slate-950 dark:hover:bg-slate-300"
      >
        Contacto
      </a>
    </div>
    <div class="mt-8 flex items-center justify-center gap-4 lg:justify-start">
      <a
        href="https://www.linkedin.com/in/andresfelipemejiar"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Perfil de LinkedIn"
        class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-700 shadow-sm transition hover:-translate-y-0.5 hover:text-slate-900 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800 dark:hover:text-slate-100"
      >
        <Icon name="fa6-brands:linkedin" class="h-6 w-6" />
      </a>
      <a
        href="https://github.com/mejia907"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Perfil de GitHub"
        class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-700 shadow-sm transition hover:-translate-y-0.5 hover:text-slate-900 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800 dark:hover:text-slate-100"
      >
        <Icon name="fa6-brands:github" class="h-6 w-6" />
      </a>
    </div>
  </div>
</section>
