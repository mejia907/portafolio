---
const itemsMenu = [
  { name: "Sobre mí", href: "#about" },
  { name: "Proyectos", href: "#projects" },
  { name: "Experiencia", href: "#experience" },
  { name: "Certificados", href: "#certificates" },
  { name: "Contacto", href: "#contact" },
];
---

<footer class="border-t border-slate-200/80 bg-white/70 py-12 transition
dark:border-slate-700 dark:bg-slate-900/70">
  <div class="mx-auto flex w-full max-w-6xl flex-col items-center justify-center px-4 sm:px-6 lg:px-8">

    {/* NAV */}
    <nav class="mb-8">
      <ul class="flex flex-col gap-3 text-center text-sm font-medium text-slate-600 sm:flex-row sm:gap-6 sm:text-base
      dark:text-slate-400">
        {
          itemsMenu.map((item) => (
            <li>
              <a
                href={item.href}
                class="transition
                hover:text-slate-900 hover:underline hover:underline-offset-8 hover:decoration-2 hover:decoration-slate-400
                dark:hover:text-white dark:hover:decoration-slate-500"
              >
                {item.name}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    {/* COPYRIGHT */}
    <p class="text-xs text-slate-500 sm:text-sm dark:text-slate-400">
      Copyright © 2025 Andrés Felipe Mejía Restrepo.
    </p>

  </div>
</footer>