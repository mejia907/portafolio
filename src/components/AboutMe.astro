---
import { Icon } from "astro-icon/components";

const itemsSkills = [
  {
    name: "PHP",
    icon: "devicon:php",
  },
  {
    name: "Laravel",
    icon: "devicon:laravel",
  },
  {
    name: "JavaScript",
    icon: "devicon:javascript",
  },
  {
    name: "TypeScript",
    icon: "devicon:typescript",
  },
  {
    name: "React",
    icon: "devicon:react",
  },
  {
    name: "Node JS",
    icon: "devicon:nodejs",
  },
  {
    name: "Astro",
    icon: "devicon:astro",
  },
  {
    name: "HTML",
    icon: "devicon:html5",
  },
  {
    name: "jQuery",
    icon: "devicon:jquery",
  },
  {
    name: "CSS",
    icon: "devicon:css3",
  },
  {
    name: "Tailwind",
    icon: "devicon:tailwindcss",
  },
];

const itemsSkillsDB = [
  {
    name: "MySQL",
    icon: "devicon:mysql",
  },
  {
    name: "MariaDB",
    icon: "devicon:mariadb",
  },
  {
    name: "MongoDB",
    icon: "devicon:mongodb",
  },
  {
    name: "PostgreSQL",
    icon: "devicon:postgresql",
  },
  {
    name: "Prisma",
    icon: "devicon:prisma",
  },
];

---

<section id="about" class="py-16 md:py-20">
  <div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-center gap-2 text-center">
      <Icon name="hugeicons:user-square" class="h-8 w-8 text-slate-700 sm:h-10 sm:w-10 dark:text-slate-300" />
      <h1 class="py-2 text-3xl font-bold text-slate-900 sm:text-4xl md:text-5xl dark:text-slate-100">
        Sobre Mí
      </h1>
    </div>
    <div class="mt-8 grid gap-4 md:grid-cols-2 md:gap-6">
      <div
        class="rounded-2xl border border-slate-200 bg-white p-6 text-center shadow-sm dark:border-slate-700 dark:bg-slate-900 dark:shadow-none"
      >
        <Icon name="hugeicons:ai-user" class="mx-auto h-10 w-10 text-slate-700 dark:text-slate-300" />
        <h3 class="mt-3 font-bold text-slate-900 dark:text-slate-100">Experiencia</h3>
        <p class="mt-2 text-sm text-slate-600 sm:text-base dark:text-slate-300">
          10+ años de desarrollo backend
        </p>
        <p class="text-sm text-slate-600 sm:text-base dark:text-slate-300">
          4+ años de desarrollo frontend
        </p>
      </div>
      <div
        class="rounded-2xl border border-slate-200 bg-white p-6 text-center shadow-sm dark:border-slate-700 dark:bg-slate-900 dark:shadow-none"
      >
        <Icon name="fluent-mdl2:education" class="mx-auto h-10 w-10 text-slate-700 dark:text-slate-300" />
        <h3 class="mt-3 font-bold text-slate-900 dark:text-slate-100">Educación</h3>
        <p class="mt-2 text-sm text-slate-600 sm:text-base dark:text-slate-300">Ingeniería de Sistemas</p>
        <p class="text-sm text-slate-600 sm:text-base dark:text-slate-300">
          Tecnólogo en Análisis y desarrollo de Sistemas de Información
        </p>
      </div>
    </div>
    <p class="mt-8 text-sm leading-relaxed text-slate-700 sm:text-base md:text-lg dark:text-slate-300">
      Como ingeniero en sistemas tengo los conocimientos, las habilidades y las
      características personales para mi adecuado desempeño en las actividades de
      análisis, diseño y programación de sistemas de información. Mi capacidad
      analítica me permite comprender necesidades del negocio y traducirlas en
      soluciones tecnológicas eficientes. Además, mi pasión por la innovación me
      impulsa a buscar constantemente nuevas formas de mejorar procesos y
      productos.
    </p>

    <div class="mt-14 flex items-center justify-center gap-2 text-center">
      <Icon name="fluent-mdl2:code" class="h-8 w-8 text-slate-700 sm:h-10 sm:w-10 dark:text-slate-300" />
      <h2 class="py-2 text-3xl font-bold text-slate-900 sm:text-4xl md:text-5xl dark:text-slate-100">
        Habilidades
      </h2>
    </div>
    <div class="mt-6 grid grid-cols-3 gap-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6">
      {
        itemsSkills.map((item) => (
          <div class="group flex flex-col items-center rounded-xl border border-slate-200 bg-white p-3 text-center shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-md dark:border-slate-700 dark:bg-slate-900 dark:shadow-none dark:hover:shadow-slate-950/40">
            <Icon name={item.icon} class="h-9 w-9 text-slate-700 sm:h-10 sm:w-10 dark:text-slate-300" />
            <span class="mt-2 text-xs font-medium text-slate-600 sm:text-sm dark:text-slate-300">
              {item.name}
            </span>
          </div>
        ))
      }
    </div>

    <div class="mt-10 flex items-center justify-center gap-2 text-center">
      <Icon name="fluent-mdl2:database" class="h-8 w-8 text-slate-700 sm:h-10 sm:w-10 dark:text-slate-300" />
      <h3 class="py-2 text-xl font-bold text-slate-900 sm:text-2xl md:text-3xl dark:text-slate-100">
        Bases de Datos
      </h3>
    </div>
    <div class="mt-6 grid grid-cols-3 gap-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6">
      {
        itemsSkillsDB.map((item) => (
          <div class="group flex flex-col items-center rounded-xl border border-slate-200 bg-white p-3 text-center shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-md dark:border-slate-700 dark:bg-slate-900 dark:shadow-none dark:hover:shadow-slate-950/40">
            <Icon name={item.icon} class="h-9 w-9 text-slate-700 sm:h-10 sm:w-10 dark:text-slate-300" />
            <span class="mt-2 text-xs font-medium text-slate-600 sm:text-sm dark:text-slate-300">
              {item.name}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>
