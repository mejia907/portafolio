---
import { Icon } from "astro-icon/components";
---

<section
  id="contact"
  class="py-16 md:py-20"
>
  <div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-center gap-2 text-center">
      <Icon
        name="iconoir:hand-contactless"
        class="h-8 w-8 sm:h-10 sm:w-10 text-slate-700 dark:text-slate-300"
      />
      <h1
        class="py-2 text-3xl font-bold text-slate-900 sm:text-4xl md:text-5xl dark:text-slate-100"
      >
        Contacto
      </h1>
    </div>

    <div
      class="mx-auto mt-8 flex w-full max-w-2xl flex-col items-center justify-center gap-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition sm:flex-row sm:gap-8 sm:p-6
      dark:border-slate-700 dark:bg-slate-900 dark:shadow-none"
    >
      {/* EMAIL */}
      <a
        href="mailto:mejia9070@gmail.com"
        class="inline-flex items-center gap-2 rounded-full px-2 py-1 text-sm text-slate-700 transition hover:text-slate-900 sm:text-base
         dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800 dark:hover:text-slate-100"
      >
        <span
          class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-slate-200 bg-slate-50 transition
          dark:border-slate-600 dark:bg-slate-800"
        >
          <Icon
            name="proicons:mail"
            class="h-5 w-5"
          />
        </span>

        <span class="break-all"> mejia9070@gmail.com </span>
      </a>

      {/* LINKEDIN */}
      <a
        href="https://www.linkedin.com/in/andresfelipemejiar"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-full px-2 py-1 text-sm text-slate-700 transition hover:text-slate-900 sm:text-base
        dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800 dark:hover:text-slate-100"
      >
        <span
          class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-slate-200 bg-slate-50 transition
          dark:border-slate-600 dark:bg-slate-800"
        >
          <Icon
            name="fa6-brands:linkedin"
            class="h-5 w-5"
          />
        </span>

        LinkedIn
      </a>
    </div>
  </div>
</section>
