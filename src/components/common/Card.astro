---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

const { image, title, description, url, github } = Astro.props;
---
<article
  class="group flex h-full flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-slate-900/10
  dark:border-slate-700 dark:bg-slate-900 dark:shadow-none"
>
  {/* Imagen */}
  <div class="h-56 overflow-hidden border-b border-slate-100 sm:h-64 dark:border-slate-700">
    <Image
      src={image}
      alt={title}
      class="h-full w-full object-cover transition duration-500 ease-in-out group-hover:scale-105"
    />
  </div>

  {/* Contenido */}
  <div class="flex flex-1 flex-col p-5 sm:p-6">
    <div class="flex-1">
      <h2 class="text-xl font-bold leading-snug text-slate-900 dark:text-slate-100">
        {title}
      </h2>
      <p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
        {description}
      </p>
    </div>

    {/* Tags */}
    <div class="mb-6 mt-5 flex flex-wrap gap-2">
      <slot />
    </div>

    {/* Actions */}
    <div class="mt-auto flex flex-wrap justify-end gap-2">
      {
        github && (
          <a
            href={github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 rounded-full border border-slate-800 bg-slate-900 px-4 py-2 text-sm font-medium text-white transition
            hover:bg-slate-700
            dark:border-slate-600 dark:bg-slate-800 dark:hover:bg-slate-700"
          >
            <Icon name="fa6-brands:github" class="h-5 w-5" />
            Ver código
          </a>
        )
      }

      {
        url && (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition
            hover:border-slate-300 hover:text-slate-900
            dark:border-slate-600 dark:bg-slate-800 dark:text-slate-300
            dark:hover:border-slate-500 dark:hover:text-white"
          >
            <Icon name="uim:arrow-up-right" class="h-5 w-5" />
            Ver ahora
          </a>
        )
      }
    </div>
  </div>
</article>