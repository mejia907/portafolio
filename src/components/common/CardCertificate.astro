---
import { Icon } from "astro-icon/components";

const { icon, iconPlatform, namePlatform, title, date, time } = Astro.props;
---
<article
  class="group flex h-full flex-col rounded-2xl border border-slate-200 bg-white px-5 py-6 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-slate-900/10 sm:px-6 sm:py-7 dark:border-slate-700 dark:bg-slate-900 dark:shadow-none dark:hover:shadow-slate-950/40"
>
  <div class="flex items-center justify-between gap-3">
    <div
      class="rounded-xl border border-slate-200 bg-white p-3 transition group-hover:border-slate-300 group-hover:bg-white dark:border-slate-700 dark:bg-slate-900 dark:shadow-none dark:hover:shadow-slate-950/40 dark:hover:border-slate-600 dark:hover:bg-slate-800 dark:group-hover:border-slate-600 dark:group-hover:bg-slate-800"
    >
      <Icon name={icon} class="h-8 w-8 sm:h-10 sm:w-10 transition duration-300 ease-in-out group-hover:scale-110 dark:text-slate-300" />
    </div>
    <div class="inline-flex items-center gap-1 text-xs text-slate-500 sm:text-sm">
      <Icon name={iconPlatform} class="h-4 w-4 text-emerald-500 sm:h-5 sm:w-5" />
      <p>{namePlatform}</p>
    </div>
  </div>
  <h3 class="mt-5 text-lg font-bold text-slate-900 sm:mt-7 sm:text-xl dark:text-slate-100">
    {title}
  </h3>
  <div class="mt-4 flex items-center justify-between text-sm text-slate-600 sm:text-base dark:text-slate-400">
    <p>{date}</p>
    {time && <span class="text-xs text-slate-500 sm:text-sm dark:text-slate-400">{time}</span>}
  </div>
</article>
