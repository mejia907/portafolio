---
import { Image } from "astro:assets";
const { image, title, description, position, dateIn, dateOut, url } = Astro.props;
---
<article
  class="group flex h-full gap-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-slate-900/5 sm:gap-5 sm:p-5 dark:border-slate-700 dark:bg-slate-900 dark:shadow-none dark:hover:shadow-slate-950/40"
>
  <a
    href={url}
    target="_blank"
    rel="noopener noreferrer"
    class="grid h-16 w-16 shrink-0 place-items-center overflow-hidden rounded-lg border border-slate-200 bg-white p-2 sm:h-20 sm:w-20"
  >
    <Image
      src={image}
      alt={title}
      class="object-cover transition duration-300 ease-in-out group-hover:scale-110"
    />
  </a>
  <div class="min-w-0">
    <h3 class="text-lg font-semibold text-slate-900 sm:text-xl dark:text-slate-100">{title}</h3>
    <p class="text-sm font-medium text-slate-600 sm:text-base dark:text-slate-300">{position}</p>
    <time class="mt-1 block text-xs uppercase tracking-widest text-slate-500 sm:text-sm dark:text-slate-400">
      {dateIn} - {dateOut}
    </time>
    <p class="mt-3 text-sm leading-relaxed text-slate-600 sm:text-base dark:text-slate-300">
      <span set:html={description}></span>
    </p>
  </div>
</article>
